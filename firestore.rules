rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return signedIn() ? userDoc().data.role : '';
    }

    function isAdmin() {
      return role() in ['Admin', 'admin'];
    }

    function isGuardian() {
      return role() in ['Guardian', 'guardian', 'Parent', 'parent'];
    }

    function isTutor() {
      return role() in ['Tutor', 'tutor'];
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /guardian_profiles/{guardianId} {
      allow read: if signedIn();
      allow create, update: if signedIn() &&
        (request.auth.uid == guardianId || isAdmin());
      allow delete: if isAdmin();
    }

    match /tutor_profiles/{tutorId} {
      allow read: if signedIn();
      allow create, update: if signedIn() &&
        (
          request.auth.uid == tutorId ||
          isAdmin() ||
          (
            isGuardian() &&
            request.resource.data.diff(resource.data).changedKeys()
              .hasOnly(['guardianRatingAverage', 'guardianTotalReviews', 'updatedAt'])
          )
        );
      allow delete: if isAdmin();
    }

    match /tuition_posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        isGuardian() &&
        request.resource.data.guardianId == request.auth.uid;
      allow update: if signedIn() &&
        (
          resource.data.guardianId == request.auth.uid ||
          isAdmin() ||
          (
            isTutor() &&
            request.resource.data.diff(resource.data).changedKeys()
              .hasOnly(['status', 'selectedTutorId', 'updatedAt'])
          )
        );
      allow delete: if signedIn() &&
        (resource.data.guardianId == request.auth.uid || isAdmin());
    }

    match /applications/{applicationId} {
      allow read: if signedIn() &&
        (
          resource.data.guardianId == request.auth.uid ||
          resource.data.tutorId == request.auth.uid ||
          isAdmin()
        );
      allow create: if signedIn() &&
        isTutor() &&
        request.resource.data.tutorId == request.auth.uid;
      allow update: if signedIn() &&
        (
          resource.data.guardianId == request.auth.uid ||
          resource.data.tutorId == request.auth.uid ||
          isAdmin()
        );
      allow delete: if isAdmin();
    }

    match /tutor_requests/{requestId} {
      allow read: if signedIn() &&
        (
          resource.data.guardianId == request.auth.uid ||
          resource.data.tutorId == request.auth.uid ||
          isAdmin()
        );
      allow create: if signedIn() &&
        request.resource.data.guardianId == request.auth.uid;
      allow update: if signedIn() &&
        (
          resource.data.guardianId == request.auth.uid ||
          resource.data.tutorId == request.auth.uid ||
          isAdmin()
        );
      allow delete: if isAdmin();
    }

    match /verification_payments/{paymentId} {
      allow read: if signedIn() &&
        (resource.data.tutorId == request.auth.uid || isAdmin());
      allow create: if signedIn() &&
        request.resource.data.tutorId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if signedIn();
      allow create, update: if signedIn() &&
        isGuardian() &&
        request.resource.data.guardianId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow create: if signedIn() &&
        request.auth.uid in request.resource.data.participants;
      allow read, update, delete: if signedIn() &&
        (
          isAdmin() ||
          request.auth.uid in resource.data.participants
        );

      match /messages/{messageId} {
        allow read: if signedIn() &&
          (
            isAdmin() ||
            request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          );
        allow create: if signedIn() &&
          request.resource.data.senderId == request.auth.uid &&
          (
            isAdmin() ||
            request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          );
        allow update, delete: if isAdmin();
      }
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
